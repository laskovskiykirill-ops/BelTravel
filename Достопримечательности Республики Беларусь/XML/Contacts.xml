<?xml version="1.0" encoding="UTF-8"?>
<page id="contacts" title="BelTravel — Наши контакты">

    <header>
        <logo>BelTravel</logo>
        <nav>
            <item id="main">Главная</item>
            <item id="contacts">Наши контакты</item>
            <item id="aboutUs">О нас</item>
        </nav>
    </header>

    <main>
        <pageTitle>Свяжитесь с нами</pageTitle>
        <subtitle>Мы всегда рады помочь вам открыть удивительную Беларусь. Оставьте сообщение или воспользуйтесь контактами ниже.</subtitle>

        <contactInfo>
            <office>
                <label>Центральный офис</label>
                <address>г. Минск, проспект Независимости, 58, офис 402</address>
                <postal>220005, Беларусь</postal>
            </office>
            <phones>
                <label>Телефоны</label>
                <phone>+375 (17) 123-45-67</phone>
                <phone note="Viber/WhatsApp">+375 (29) 678-90-12</phone>
            </phones>
            <emails>
                <label>Электронная почта</label>
                <email>info@beltravel.by</email>
                <email>tours@beltravel.by</email>
            </emails>
            <workingHours>
                <label>Режим работы</label>
                <hours day="Пн–Пт">09:00 – 19:00</hours>
                <hours day="Сб">10:00 – 16:00</hours>
                <hours day="Вс">выходной</hours>
            </workingHours>
        </contactInfo>

        <contactForm id="contactForm">
            <title>Напишите нам</title>
            <description>Заполните форму, и наш специалист свяжется с вами в ближайшее время.</description>
            <fields>
                <field id="fieldName" type="text" label="Ваше имя" placeholder="Иван Петров" required="true"/>
                <field id="fieldEmail" type="email" label="E-mail" placeholder="ivan@example.com" required="true"/>
                <field id="fieldPhone" type="tel" label="Телефон" placeholder="+375 (29) 123-45-67" required="true"/>
                <field id="fieldTopic" type="select" label="Тема сообщения" required="true">
                    <option value="">– Выберите тему –</option>
                    <option>Экскурсии и туры</option>
                    <option>Бронирование отелей</option>
                    <option>Консультация по достопримечательностям</option>
                    <option>Сотрудничество</option>
                    <option>Другой вопрос</option>
                </field>
                <field id="fieldMessage" type="textarea" label="Сообщение" placeholder="Расскажите, чем мы можем вам помочь..." rows="5" required="true"/>
                <field id="fieldConsent" type="checkbox" label="Я согласен на обработку персональных данных" required="true"/>
            </fields>
            <submitButton>Отправить сообщение</submitButton>
        </contactForm>
    </main>

    <footer>
        <text>© 2025 BelTravel — Путешествуйте с любовью к Беларуси. Все права защищены.</text>
        <text>Достопримечательности Беларуси: Мирский замок, Беловежская пуща, Несвиж, Брестская крепость и другие жемчужины.</text>
    </footer>

    <scripts>
        <script src="../JS/menu.js"/>
        <script src="../JS/contacts.js"/>
    </scripts>

</page>
